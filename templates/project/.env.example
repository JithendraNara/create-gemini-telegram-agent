# Runtime configuration for Gemini Telegram Agent
BOT_TOKEN_FILE=~/.config/gemini-telegram-agent/telegram-bot-token.txt
GEMINI_PATH=gemini
GEMINI_MODEL=gemini-2.5-flash

REQUEST_TIMEOUT_SEC=300
MAX_CONCURRENT_PROCESSES=3
MAX_INPUT_CHARS=2000
RATE_LIMIT_PER_MIN=12
RATE_LIMIT_BURST=3
RATE_LIMIT_WINDOW_SEC=60

CLI_TIMEOUT_SEC=60
CLI_CHAIN_MAX=8
SESSIONS_LIST_DEFAULT_LIMIT=25
SESSIONS_LIST_MAX_LIMIT=200
SESSION_IDLE_RESET_SEC=1800

# Optional chat allowlist (comma-separated chat ids)
ALLOWED_CHAT_IDS=
